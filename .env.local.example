# ---------------------------------------------------------------------------
# GroomOS — Supabase environment (Stage 1 foundation)
#
# Copy this file to ".env.local" and paste your own values from the Supabase
# dashboard (Project Settings -> API). ".env.local" is gitignored — never
# commit real keys. Restart `npm run dev` after editing.
#
# Nothing in the working demo reads these yet; they're here ready for Stage 2.
# ---------------------------------------------------------------------------

# Project URL — Settings -> API -> "Project URL"
# (newer dashboards: Settings -> Data API). Looks like https://abcd1234.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Anon / public key — safe to expose in the browser.
# Settings -> API -> "Project API keys" -> anon / public
# (newer dashboards: Settings -> API Keys -> "Publishable key")
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Service role / secret key — SERVER ONLY.
# Never prefix with NEXT_PUBLIC, never expose in the browser, never commit.
# Used by server code in a later stage (seeding, admin tasks).
# Settings -> API -> "Project API keys" -> service_role (click Reveal)
# (newer dashboards: Settings -> API Keys -> "Secret key")
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET-KEY
